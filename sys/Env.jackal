object Env() {
    let path;
    let chache : Map = {}

    func load(file_path : String) -> Boolean {
        path = file_path;
        chache = __env_load__(path)
        return true
    }

    func get(key : String , defaultValue : String){
        let value = chache[key]

        if value == nil 
            return defaultValue
            
        return value
    }




}