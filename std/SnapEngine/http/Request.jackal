object Request(){

    let _raw = nil

    func _setRaw(data) {
        _raw = data
    }

    func header(key) {
        return _raw["headers"][key]
    }

    func param(key) {
        return _raw["params"][key]
    }

    func body(key) {
        return _raw["body"][key]
    }

    func query(key) {
        return _raw["query"][key]
    }

    func forward(host, port){
        return __native_forward__(_raw, host, port)
    }
}