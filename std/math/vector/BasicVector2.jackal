import std.numeric.Abstract.AbstractNumeric 
import std.numeric.Coordinate

class BasicVector2 : Coordinate , AbstractNumericMethod {

    @override
    func dot(v : BasicVector2) -> BasicVector2 = 
        BasicVector2((this.x * v.x), (this.y * v.y))

    @override
    func add(v : BasicVector2) -> BasicVector2 = 
        BasicVector2((this.x + v.x) , (this.y + v.y))

    @override
    func sub(v : BasicVector2) -> BasicVector2 = 
        BasicVector2((this.x - v.x) , (this.y - v.y))


    
}