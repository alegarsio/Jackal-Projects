class BasicVector2 {
    init(x, y) {
        this.x = x
        this.y = y
    }

    func dot(v : BasicVector2) {
       let newx = this.x * v.x
       let newy = this.y * v.y

       return BasicVector2(newx , newy)
    }

    func add(v) {
        let newX = this.x + v.x
        let newY = this.y + v.y
        
        return BasicVector2(newX, newY)
    }
}